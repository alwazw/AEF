{
  "gateway": {
    "mode": "local"
  },
  "logging": {
    "level": "debug",
    "consoleLevel": "debug"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "litellm": {
        "baseUrl": "http://ai-litellm:4000/v1",
        "apiKey": "${LITELLM_MASTER_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "morpheus-core",
            "name": "Morpheus Core",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 1000000,
            "contextTokens": 256000,
            "maxTokens": 64000
          },
          {
            "id": "morpheus-deep-thought",
            "name": "Morpheus Deep Thought",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 1000000,
            "contextTokens": 256000,
            "maxTokens": 64000
          },
          {
            "id": "morpheus-flash",
            "name": "Morpheus Flash",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 1000000,
            "contextTokens": 256000,
            "maxTokens": 8192
          },
          {
            "id": "morpheus-qwen",
            "name": "Morpheus Qwen",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 1000000,
            "contextTokens": 256000,
            "maxTokens": 8192
          },
          {
            "id": "morpheus-free-fallback",
            "name": "Morpheus Free Fallback",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 128000,
            "contextTokens": 96000,
            "maxTokens": 8192
          },
          {
            "id": "local-processor",
            "name": "Local Processor",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 32768,
            "contextTokens": 32000,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": "litellm/local-processor",
      "compaction": {
        "reserveTokensFloor": 6000,
        "keepRecentTokens": 12000,
        "model": "litellm/morpheus-flash"
      }
    }
  }
}
